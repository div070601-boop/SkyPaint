<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════════════════════════════════════════════════════
         LAYER 0: Full-bleed 3D Canvas (SurfaceView)
         ═══════════════════════════════════════════════════════════════════ -->
    <com.feather3d.app.Feather3DView
        android:id="@+id/feather3dView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL A: System Menu — Top-Left
         Home / Settings / Export
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelSystemMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SkyPaint"
            android:textColor="#3949AB"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center_vertical"
            android:paddingStart="6dp"
            android:paddingEnd="12dp" />

        <!-- Settings -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            app:tint="#616161"
            android:layout_marginEnd="4dp" />

        <!-- Export -->
        <ImageButton
            android:id="@+id/btnExport"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_export"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Export"
            app:tint="#616161" />

        <!-- Objects List toggle -->
        <ImageButton
            android:id="@+id/btnObjectList"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_layers"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Objects"
            app:tint="#616161" />
    </LinearLayout>

    <!-- Scene Objects Panel (bottom-left, toggleable) -->
    <LinearLayout
        android:id="@+id/panelObjectList"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:maxHeight="250dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_panel"
        android:elevation="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="80dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scene Objects"
            android:textColor="#424242"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp">

            <LinearLayout
                android:id="@+id/objectListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>
    </LinearLayout>

    <!-- Stats overlay — TopCenter -->
    <TextView
        android:id="@+id/statsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="V: 0 | T: 0"
        android:textColor="#99757575"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:layout_margin="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL B: Tool Menu — Top-Right
         Draw / Sculpt / Erase / Liquify / Mirror
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelToolMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Navigate -->
        <ImageButton
            android:id="@+id/btnModeNavigate"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_move"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Navigate"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <!-- Draw -->
        <ImageButton
            android:id="@+id/btnModeDraw"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_draw"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Draw"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <!-- Sculpt -->
        <ImageButton
            android:id="@+id/btnModeSculpt"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_sculpt"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Sculpt"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <!-- Primitives -->
        <ImageButton
            android:id="@+id/btnModePrimitives"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_shapes"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Primitives"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <!-- Select -->
        <ImageButton
            android:id="@+id/btnModeSelect"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_select"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Select"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <!-- Erase -->
        <ImageButton
            android:id="@+id/btnModeErase"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_eraser"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Erase"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <!-- Liquify -->
        <ImageButton
            android:id="@+id/btnModeLiquify"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_liquify"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Liquify"
            app:tint="#424242"
            android:layout_margin="2dp" />

        <ImageButton
            android:id="@+id/btnMirror"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_mirror"
            android:background="@drawable/bg_tool_btn"
            android:contentDescription="Mirror"
            app:tint="#424242"
            android:layout_margin="2dp" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL G: Drafting Tools — Right Edge (Below Tool Menu)
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelDrafting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="4dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/panelToolMenu"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStraight"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="L"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_margin="2dp"
            android:backgroundTint="#00000000" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGridSnap"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="#"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_margin="2dp"
            android:backgroundTint="#00000000" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAngleSnap"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="∠"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_margin="2dp"
            android:backgroundTint="#00000000" />

        <View
            android:layout_width="32dp"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="6dp"
            android:layout_gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnapView"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="[ ]"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_margin="2dp"
            android:backgroundTint="#00000000" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOrtho"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="3D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetBottom="0dp"
            android:insetTop="0dp"
            android:layout_margin="2dp"
            android:backgroundTint="#00000000" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL C: Brush Panel — Left Sidebar (Thumb Reach)
         Brush Size Slider (vertical) + Color Picker
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelBrushSidebar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginStart="12dp"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Brush size label -->
        <TextView
            android:id="@+id/brushSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="20"
            android:textColor="#757575"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <!-- Vertical brush size slider -->
        <SeekBar
            android:id="@+id/brushSizeSlider"
            android:layout_width="200dp"
            android:layout_height="36dp"
            android:min="1"
            android:max="100"
            android:progress="20"
            android:progressTint="#5C6BC0"
            android:thumbTint="#7C4DFF"
            android:rotation="270"
            android:layout_marginTop="80dp"
            android:layout_marginBottom="80dp" />

        <!-- Color picker button -->
        <ImageButton
            android:id="@+id/btnColorPicker"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_palette"
            android:background="@drawable/bg_color_swatch"
            android:contentDescription="Color"
            app:tint="#7C4DFF"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL D: History — Bottom-Left
         Undo / Redo
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_undo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Undo"
            app:tint="#C0C0E0"
            android:layout_margin="2dp" />

        <!-- Redo -->
        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_redo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Redo"
            app:tint="#C0C0E0"
            android:layout_margin="2dp" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         Floating Dimension Readout
         ═══════════════════════════════════════════════════════════════════ -->
    <TextView
        android:id="@+id/textDimension"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12.4m"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_floating_panel"
        android:backgroundTint="#E0212121"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:elevation="12dp"
        android:visibility="gone"
        android:layout_marginBottom="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/panelContextMenu" />

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL E: Context Menu — Bottom-Center
         Sub-mode buttons (dynamic based on active tool)
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelContextMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Sculpt sub-modes (visible when Sculpt is active) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubAdd"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Add"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubSub"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Sub"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubSmooth"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Smooth"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubInflate"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Inflate"
            android:textSize="12sp"
            android:textColor="#C0C0E0"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubPinch"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Pinch"
            android:textSize="12sp"
            android:textColor="#C0C0E0"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp" />

        <!-- Clear All -->
        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_clear"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Clear all"
            app:tint="#E53935"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════
         PANEL F: Color Palette — Bottom-Right
         Quick color swatches for stroke color
         ═══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelColorPalette"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_floating_panel"
        android:elevation="8dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- White -->
        <View android:id="@+id/colorWhite"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#FFFFFF"
            android:layout_margin="3dp" />

        <!-- Black -->
        <View android:id="@+id/colorBlack"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#333333"
            android:layout_margin="3dp" />

        <!-- Red -->
        <View android:id="@+id/colorRed"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#E53935"
            android:layout_margin="3dp" />

        <!-- Orange -->
        <View android:id="@+id/colorOrange"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#FB8C00"
            android:layout_margin="3dp" />

        <!-- Yellow -->
        <View android:id="@+id/colorYellow"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#FDD835"
            android:layout_margin="3dp" />

        <!-- Green -->
        <View android:id="@+id/colorGreen"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#43A047"
            android:layout_margin="3dp" />

        <!-- Cyan -->
        <View android:id="@+id/colorCyan"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#00BCD4"
            android:layout_margin="3dp" />

        <!-- Blue -->
        <View android:id="@+id/colorBlue"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#1E88E5"
            android:layout_margin="3dp" />

        <!-- Purple -->
        <View android:id="@+id/colorPurple"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#7C4DFF"
            android:layout_margin="3dp" />

        <!-- Pink -->
        <View android:id="@+id/colorPink"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_color_swatch"
            android:backgroundTint="#EC407A"
            android:layout_margin="3dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubPrimCube"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Cube"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubPrimSphere"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Sphere"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubPrimCylinder"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Cyl"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubPrimCone"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Cone"
            android:textSize="12sp"
            android:textColor="#616161"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteSelected"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Delete"
            android:textSize="12sp"
            android:textColor="#D32F2F"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDuplicateSelected"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Dupe"
            android:textSize="12sp"
            android:textColor="#1565C0"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
